<!-- ============================================================
     USER-DEFINED DATA TYPES (UDTs)
     Custom structures that group related data together.
     ============================================================ -->
<DataTypes Use="Context">
<DataType Use="Target" Name="udtPartRecord" Family="NoFamily" Class="User">
<Description><![CDATA[Part inspection record - groups all data about a single inspected part into one reusable structure. Demonstrates mixed data types in a UDT.]]></Description>
<Members>
<Member Name="PartID" DataType="DINT" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
<Description><![CDATA[Unique part identifier (1-999999)]]></Description>
</Member>
<Member Name="Weight" DataType="REAL" Dimension="0" Radix="Float" Hidden="false" ExternalAccess="Read/Write">
<Description><![CDATA[Measured part weight in grams]]></Description>
</Member>
<Member Name="TargetWeight" DataType="REAL" Dimension="0" Radix="Float" Hidden="false" ExternalAccess="Read/Write">
<Description><![CDATA[Target weight specification]]></Description>
</Member>
<Member Name="Tolerance" DataType="REAL" Dimension="0" Radix="Float" Hidden="false" ExternalAccess="Read/Write">
<Description><![CDATA[Weight tolerance (+/- grams)]]></Description>
</Member>
<Member Name="InspectionResult" DataType="DINT" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
<Description><![CDATA[0=Pending 1=Pass 2=Fail_Under 3=Fail_Over 4=Fail_Other]]></Description>
</Member>
<Member Name="InspectionTime_ms" DataType="DINT" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
<Description><![CDATA[Inspection duration in milliseconds]]></Description>
</Member>
<Member Name="Timestamp" DataType="DINT" Dimension="7" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
<Description><![CDATA[Timestamp array: [Year,Month,Day,Hour,Minute,Second,Millisecond]]]></Description>
</Member>
</Members>
</DataType>

<DataType Use="Target" Name="udtMotorStarter" Family="NoFamily" Class="User">
<Description><![CDATA[Motor starter status block - groups all motor control and feedback signals. Used as backing tag for aoiMotorStarter AOI.]]></Description>
<Members>
<Member Name="RunCommand" DataType="BOOL" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
<Description><![CDATA[Run command from logic]]></Description>
</Member>
<Member Name="Running" DataType="BOOL" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
<Description><![CDATA[Motor running feedback]]></Description>
</Member>
<Member Name="Faulted" DataType="BOOL" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
<Description><![CDATA[Motor fault detected]]></Description>
</Member>
<Member Name="OverloadTrip" DataType="BOOL" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
<Description><![CDATA[Overload protection tripped]]></Description>
</Member>
<Member Name="RunHours" DataType="REAL" Dimension="0" Radix="Float" Hidden="false" ExternalAccess="Read/Write">
<Description><![CDATA[Accumulated run time in hours]]></Description>
</Member>
<Member Name="StartCount" DataType="DINT" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
<Description><![CDATA[Number of motor starts]]></Description>
</Member>
<Member Name="FaultCode" DataType="DINT" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
<Description><![CDATA[Fault code: 0=OK 1=Overload 2=ContactorFail 3=FeedbackTimeout]]></Description>
</Member>
</Members>
</DataType>
</DataTypes>

<!-- ============================================================
     ADD-ON INSTRUCTION DEFINITION (AOI)
     Reusable motor starter block - the "function" of PLC programming.
     ============================================================ -->
<AddOnInstructionDefinitions Use="Context">
<AddOnInstructionDefinition Use="Target" Name="aoiMotorStarter" Class="Standard" Revision="1.0" Vendor="Training" ExecutePrescan="false" ExecutePostscan="false" ExecuteEnableInFalse="false" CreatedDate="2026-06-24T09:00:00.000Z" CreatedBy="Training" EditedDate="2026-06-24T09:00:00.000Z" EditedBy="Training" SoftwareRevision="v32.05">
<Description><![CDATA[Reusable motor starter control block. Demonstrates AOI concepts: Input parameters (Start, Stop, FaultReset), Output parameters (Running, Faulted), InOut parameters (backing UDT tag), local tags, and internal logic routines. One AOI instance can be reused for multiple motors.]]></Description>
<Parameters>
<Parameter Name="EnableIn" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="false" Visible="false" ExternalAccess="Read Only">
<Description><![CDATA[Enable Input - System Defined Parameter]]></Description>
</Parameter>
<Parameter Name="EnableOut" TagType="Base" DataType="BOOL" Usage="Output" Radix="Decimal" Required="false" Visible="false" ExternalAccess="Read Only">
<Description><![CDATA[Enable Output - System Defined Parameter]]></Description>
</Parameter>
<Parameter Name="Start" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="true" Visible="true" ExternalAccess="Read Only">
<Description><![CDATA[Rising edge starts the motor]]></Description>
<DefaultData Format="L5K"><![CDATA[0]]></DefaultData>
<DefaultData Format="Decorated"><DataValue DataType="BOOL" Radix="Decimal" Value="0"/></DefaultData>
</Parameter>
<Parameter Name="Stop" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="true" Visible="true" ExternalAccess="Read Only">
<Description><![CDATA[Rising edge stops the motor]]></Description>
<DefaultData Format="L5K"><![CDATA[0]]></DefaultData>
<DefaultData Format="Decorated"><DataValue DataType="BOOL" Radix="Decimal" Value="0"/></DefaultData>
</Parameter>
<Parameter Name="FaultReset" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="true" Visible="true" ExternalAccess="Read Only">
<Description><![CDATA[Rising edge clears fault and allows restart]]></Description>
<DefaultData Format="L5K"><![CDATA[0]]></DefaultData>
<DefaultData Format="Decorated"><DataValue DataType="BOOL" Radix="Decimal" Value="0"/></DefaultData>
</Parameter>
<Parameter Name="FeedbackRun" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="true" Visible="true" ExternalAccess="Read Only">
<Description><![CDATA[Motor running feedback from contactor auxiliary contact]]></Description>
<DefaultData Format="L5K"><![CDATA[0]]></DefaultData>
<DefaultData Format="Decorated"><DataValue DataType="BOOL" Radix="Decimal" Value="0"/></DefaultData>
</Parameter>
<Parameter Name="Overload" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="true" Visible="true" ExternalAccess="Read Only">
<Description><![CDATA[Overload relay input - TRUE = overloaded]]></Description>
<DefaultData Format="L5K"><![CDATA[0]]></DefaultData>
<DefaultData Format="Decorated"><DataValue DataType="BOOL" Radix="Decimal" Value="0"/></DefaultData>
</Parameter>
<Parameter Name="FeedbackTimeout_ms" TagType="Base" DataType="DINT" Usage="Input" Radix="Decimal" Required="true" Visible="true" ExternalAccess="Read Only">
<Description><![CDATA[Maximum time (ms) to wait for feedback after start command before faulting]]></Description>
<DefaultData Format="L5K"><![CDATA[2000]]></DefaultData>
<DefaultData Format="Decorated"><DataValue DataType="DINT" Radix="Decimal" Value="2000"/></DefaultData>
</Parameter>
<Parameter Name="Running" TagType="Base" DataType="BOOL" Usage="Output" Radix="Decimal" Required="true" Visible="true" ExternalAccess="Read Only">
<Description><![CDATA[TRUE = motor is running (feedback confirmed)]]></Description>
<DefaultData Format="L5K"><![CDATA[0]]></DefaultData>
<DefaultData Format="Decorated"><DataValue DataType="BOOL" Radix="Decimal" Value="0"/></DefaultData>
</Parameter>
<Parameter Name="Faulted" TagType="Base" DataType="BOOL" Usage="Output" Radix="Decimal" Required="true" Visible="true" ExternalAccess="Read Only">
<Description><![CDATA[TRUE = motor is faulted and cannot start]]></Description>
<DefaultData Format="L5K"><![CDATA[0]]></DefaultData>
<DefaultData Format="Decorated"><DataValue DataType="BOOL" Radix="Decimal" Value="0"/></DefaultData>
</Parameter>
<Parameter Name="Status" TagType="Base" DataType="udtMotorStarter" Usage="InOut" Required="true" Visible="true" Constant="false">
<Description><![CDATA[Backing UDT tag that holds accumulated data (RunHours, StartCount, etc.)]]></Description>
</Parameter>
</Parameters>
<LocalTags>
<LocalTag Name="FeedbackTimer" DataType="TIMER" Radix="Decimal" ExternalAccess="None">
<Description><![CDATA[Timer to detect feedback timeout fault]]></Description>
</LocalTag>
<LocalTag Name="StartONS" DataType="BOOL" Radix="Decimal" ExternalAccess="None">
<Description><![CDATA[One-shot for start command]]></Description>
<DefaultData Format="L5K"><![CDATA[0]]></DefaultData>
<DefaultData Format="Decorated"><DataValue DataType="BOOL" Radix="Decimal" Value="0"/></DefaultData>
</LocalTag>
<LocalTag Name="RunHourTimer" DataType="TIMER" Radix="Decimal" ExternalAccess="None">
<Description><![CDATA[Accumulates seconds for run-hour calculation]]></Description>
</LocalTag>
<LocalTag Name="HourAccum" DataType="REAL" Radix="Float" ExternalAccess="None">
<Description><![CDATA[Accumulator for fractional hour calculation]]></Description>
<DefaultData Format="L5K"><![CDATA[0.0]]></DefaultData>
<DefaultData Format="Decorated"><DataValue DataType="REAL" Radix="Float" Value="0.0"/></DefaultData>
</LocalTag>
</LocalTags>
<Routines>
<Routine Name="Logic" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment><![CDATA[Seal-in circuit: Start latches RunCommand, Stop or Fault breaks the seal. Classic motor control pattern.]]></Comment>
<Text><![CDATA[XIC(Start)ONS(StartONS)[XIC(Status.RunCommand),XIC(StartONS)]XIO(Stop)XIO(Faulted)OTE(Status.RunCommand);]]></Text>
</Rung>
<Rung Number="1" Type="N">
<Comment><![CDATA[Feedback timeout detection: if commanded to run but no feedback within FeedbackTimeout_ms, declare fault.]]></Comment>
<Text><![CDATA[XIC(Status.RunCommand)XIO(FeedbackRun)TON(FeedbackTimer,FeedbackTimeout_ms,?);]]></Text>
</Rung>
<Rung Number="2" Type="N">
<Comment><![CDATA[Running status: TRUE when feedback confirms motor is running.]]></Comment>
<Text><![CDATA[XIC(Status.RunCommand)XIC(FeedbackRun)OTE(Running);]]></Text>
</Rung>
<Rung Number="3" Type="N">
<Comment><![CDATA[Fault detection: overload trip OR feedback timeout OR general fault. Latched until reset.]]></Comment>
<Text><![CDATA[[XIC(Overload),XIC(FeedbackTimer.DN),XIC(Status.Faulted)]OTL(Faulted);]]></Text>
</Rung>
<Rung Number="4" Type="N">
<Comment><![CDATA[Fault code assignment (CPT for conditional logic in math). 0=OK, 1=Overload, 2=FeedbackFail.]]></Comment>
<Text><![CDATA[XIC(Overload)MOV(1,Status.FaultCode);]]></Text>
</Rung>
<Rung Number="5" Type="N">
<Comment><![CDATA[Fault code 2 = feedback timeout]]></Comment>
<Text><![CDATA[XIC(FeedbackTimer.DN)MOV(2,Status.FaultCode);]]></Text>
</Rung>
<Rung Number="6" Type="N">
<Comment><![CDATA[Fault reset: clear all fault states on rising edge of FaultReset.]]></Comment>
<Text><![CDATA[XIC(FaultReset)OTU(Faulted)MOV(0,Status.FaultCode);]]></Text>
</Rung>
<Rung Number="7" Type="N">
<Comment><![CDATA[Count motor starts (each rising edge of RunCommand).]]></Comment>
<Text><![CDATA[XIC(Status.RunCommand)ONS(StartONS)CTU(Status.StartCount,?,?);]]></Text>
</Rung>
<Rung Number="8" Type="N">
<Comment><![CDATA[Run hour accumulation: run a 1-second timer while Running, accumulate in REAL. 3600 seconds = 1 hour.]]></Comment>
<Text><![CDATA[XIC(Running)TON(RunHourTimer,1000,?);]]></Text>
</Rung>
<Rung Number="9" Type="N">
<Comment><![CDATA[Each second, add 1/3600 hour to accumulator. CPT computes: Status.RunHours + (1.0 / 3600.0).]]></Comment>
<Text><![CDATA[XIC(RunHourTimer.DN)CPT(Status.RunHours,Status.RunHours + 0.0002778);]]></Text>
</Rung>
</RLLContent>
</Routine>
</Routines>
</AddOnInstructionDefinition>
</AddOnInstructionDefinitions>

